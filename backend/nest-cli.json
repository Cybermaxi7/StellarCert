{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "assets": [
      {
        "include": "modules/email/templates/**/*",
        "outDir": "dist/modules/email/templates"
      },
      {
        "include": "email/templates/**/*",
        "outDir": "dist/email/templates"
      }
    ]
  }
}